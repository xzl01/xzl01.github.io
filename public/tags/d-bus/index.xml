&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; @org.freedesktop.DBus.Property.EmitsChangedSignal(&amp;#34;const&amp;#34;)
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; readonly u NAutoVTs = ...;
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; @org.freedesktop.DBus.Property.EmitsChangedSignal(&amp;#34;const&amp;#34;)
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; readonly as KillOnlyUsers = [&amp;#39;...&amp;#39;, ...];
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; @org.freedesktop.DBus.Property.EmitsChangedSignal(&amp;#34;const&amp;#34;)
&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt; readonly as KillExcludeUsers = [&amp;#39;...&amp;#39;, ...];
